{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cargo build --features dev && \"C:/Program Files/AutoHotkey/v2/AutoHotkey64.exe\" \"C:/Users/yuriy/.claude/scripts/notify.ahk\" --title Claude --message Build_complete --icon ✅ --bg 1a2e1a --duration 5000",
            "timeout": 120,
            "statusMessage": "Building with dev features..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "WebSearch",
      "Bash(cargo check:*)",
      "Bash(cargo expand:*)",
      "Bash(git add:*)",
      "WebFetch(domain:www.poewiki.net)",
      "WebFetch(domain:poedb.tw)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:repoe-fork.github.io)",
      "WebFetch(domain:pathofexile.fandom.com)",
      "Skill(commit)",
      "Bash(wc:*)",
      "WebFetch(domain:docs.rs)",
      "Bash(timeout 5 cargo run:*)",
      "Bash(timeout 8 cargo run:*)",
      "WebFetch(domain:bevy.org)",
      "Bash(grep:*)",
      "Bash(RUST_LOG=info cargo run:*)",
      "Bash(cargo run:*)",
      "Bash(claude-code agent start:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:lib.rs)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(done)",
      "Bash(git mv:*)",
      "Bash(cargo fix:*)",
      "Bash(cargo test:*)",
      "Bash(git log:*)",
      "WebFetch(domain:www.pathofexile.com)",
      "WebFetch(domain:store.steampowered.com)",
      "WebFetch(domain:steamspy.com)"
    ],
    "additionalDirectories": [
      "D:/Projects/_reference"
    ]
  }
}
